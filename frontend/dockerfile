# ============================================
# Этап 1: Сборка приложения (builder)
# ============================================
FROM node:20-alpine AS builder

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы с зависимостями
COPY package*.json ./

# Устанавливаем зависимости
RUN npm ci --only=production && npm cache clean --force

# Копируем исходный код
COPY . .

# Собираем приложение
RUN npx webpack --mode production

# ============================================
# Этап 2: Production сервер (nginx)
# ============================================
FROM nginx:alpine

# Копируем собранные файлы из этапа builder
COPY --from=builder /app/dist /usr/share/nginx/html

# 📌 Копируем статические файлы напрямую из папки public в корень сайта
COPY public/manifest.json /usr/share/nginx/html/
COPY public/service-worker.js /usr/share/nginx/html/

# Копируем конфигурацию nginx для SPA
RUN echo 'server { \
    listen 80; \
    server_name localhost; \
    root /usr/share/nginx/html; \
    index index.html; \
    \
    # Поддержка SPA (перенаправление всех маршрутов на index.html) \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
    \
    # Оптимизация кэширования статических ресурсов \
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ { \
        expires 1y; \
        add_header Cache-Control "public, immutable"; \
    } \
    \
    # Кэширование для manifest.json и service-worker.js \
    location = /manifest.json { \
        add_header Cache-Control "no-cache"; \
    } \
    \
    location = /service-worker.js { \
        add_header Cache-Control "no-cache"; \
    } \
    \
    # Сжатие \
    gzip on; \
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript; \
}' > /etc/nginx/conf.d/default.conf

# Открываем порт 80
EXPOSE 80

# Запускаем nginx
CMD ["nginx", "-g", "daemon off;"]