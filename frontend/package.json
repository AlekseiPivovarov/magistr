    "@babel/preset-typescript": "^7.22.5",
    "@types/node": "^25.7.0",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@types/webpack": "^5.28.5",
    "@types/webpack-dev-server": "^4.7.1",
